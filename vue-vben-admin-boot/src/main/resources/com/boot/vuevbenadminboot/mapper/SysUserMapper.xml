<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.vuevbenadminboot.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.boot.vuevbenadminboot.domain.SysUser">
            <id property="id" column="id" />
            <result property="username" column="username" />
            <result property="password" column="password" />
            <result property="nickname" column="nickname" />
            <result property="avatar" column="avatar" />
            <result property="role" column="role" />
            <result property="homePath" column="home_path" />
            <result property="userDesc" column="user_desc" />
            <result property="status" column="status" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
            <result property="deleted" column="deleted" />
    </resultMap>

    <sql id="Base_Column_List">
        id,username,password,nickname,avatar,role,home_path,user_desc,status,
        create_time,update_time,deleted
    </sql>
    <select id="selectByUsername" resultType="com.boot.vuevbenadminboot.domain.SysUser">
        select <include refid="Base_Column_List" />
        from sys_user
        where username = #{username}
    </select>
</mapper>
